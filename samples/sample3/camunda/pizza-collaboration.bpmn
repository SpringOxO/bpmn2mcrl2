<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Pizza_Perfect" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <bpmn:collaboration id="Collaboration_Pizza">
    <bpmn:participant id="Participant_Customer" name="Pizza Customer" processRef="Process_Customer" />
    <bpmn:participant id="Participant_Vendor" name="Pizza vendor" processRef="Process_Vendor" />
    <bpmn:messageFlow id="MessageFlow_Order" name="pizza order" sourceRef="Task_OrderPizza" targetRef="StartEvent_Vendor" messageRef="Msg_Order" />
    <bpmn:messageFlow id="MessageFlow_Ask" sourceRef="Task_AskPizza" targetRef="CatchEvent_WhereIsMyPizza" />
    <bpmn:messageFlow id="MessageFlow_CalmResponse" sourceRef="Task_CalmCustomer" targetRef="Task_AskPizza" />
    <bpmn:messageFlow id="MessageFlow_PizzaDelivered" name="pizza" sourceRef="Task_DeliverPizza" targetRef="CatchEvent_PizzaReceived" messageRef="Msg_Pizza" />
    <bpmn:messageFlow id="MessageFlow_Money" name="money" sourceRef="Task_PayPizza" targetRef="Task_ReceivePayment" messageRef="Msg_Money" />
    <bpmn:messageFlow id="MessageFlow_Receipt" name="receipt" sourceRef="Task_ReceivePayment" targetRef="Task_PayPizza" messageRef="Msg_Receipt" />
  </bpmn:collaboration>
  <bpmn:message id="Msg_Order" />
  <bpmn:message id="Msg_Pizza" />
  <bpmn:message id="Msg_Money" />
  <bpmn:message id="Msg_Receipt" />
  <bpmn:process id="Process_Customer" isExecutable="false">
    <bpmn:startEvent id="StartEvent_Customer" name="Hungry for pizza">
      <bpmn:outgoing>Flow_Cust_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_SelectPizza" name="Select a pizza">
      <bpmn:incoming>Flow_Cust_1</bpmn:incoming>
      <bpmn:outgoing>Flow_Cust_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_OrderPizza" name="Order a pizza">
      <bpmn:incoming>Flow_Cust_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Cust_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:eventBasedGateway id="Gateway_EventBased">
      <bpmn:incoming>Flow_Cust_3</bpmn:incoming>
      <bpmn:incoming>Flow_Cust_Loop</bpmn:incoming>
      <bpmn:outgoing>Flow_Cust_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_Cust_5</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="CatchEvent_Timer" name="60 minutes">
      <bpmn:incoming>Flow_Cust_5</bpmn:incoming>
      <bpmn:outgoing>Flow_Cust_7</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TE_1" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_AskPizza" name="Ask for the pizza">
      <bpmn:incoming>Flow_Cust_7</bpmn:incoming>
      <bpmn:outgoing>Flow_Cust_Loop</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_PayPizza" name="Pay the pizza">
      <bpmn:incoming>Flow_Cust_6</bpmn:incoming>
      <bpmn:outgoing>Flow_Cust_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_EatPizza" name="Eat the pizza">
      <bpmn:incoming>Flow_Cust_8</bpmn:incoming>
      <bpmn:outgoing>Flow_Cust_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_Customer" name="Hunger satisfied">
      <bpmn:incoming>Flow_Cust_9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Cust_1" sourceRef="StartEvent_Customer" targetRef="Task_SelectPizza" />
    <bpmn:sequenceFlow id="Flow_Cust_2" sourceRef="Task_SelectPizza" targetRef="Task_OrderPizza" />
    <bpmn:sequenceFlow id="Flow_Cust_3" sourceRef="Task_OrderPizza" targetRef="Gateway_EventBased" />
    <bpmn:sequenceFlow id="Flow_Cust_Loop" sourceRef="Task_AskPizza" targetRef="Gateway_EventBased" />
    <bpmn:sequenceFlow id="Flow_Cust_4" sourceRef="Gateway_EventBased" targetRef="CatchEvent_PizzaReceived" />
    <bpmn:sequenceFlow id="Flow_Cust_5" sourceRef="Gateway_EventBased" targetRef="CatchEvent_Timer" />
    <bpmn:sequenceFlow id="Flow_Cust_6" sourceRef="CatchEvent_PizzaReceived" targetRef="Task_PayPizza" />
    <bpmn:sequenceFlow id="Flow_Cust_7" sourceRef="CatchEvent_Timer" targetRef="Task_AskPizza" />
    <bpmn:sequenceFlow id="Flow_Cust_8" sourceRef="Task_PayPizza" targetRef="Task_EatPizza" />
    <bpmn:sequenceFlow id="Flow_Cust_9" sourceRef="Task_EatPizza" targetRef="EndEvent_Customer" />
    <bpmn:intermediateCatchEvent id="CatchEvent_PizzaReceived" name="pizza received">
      <bpmn:incoming>Flow_Cust_4</bpmn:incoming>
      <bpmn:outgoing>Flow_Cust_6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="ME_1" />
    </bpmn:intermediateCatchEvent>
  </bpmn:process>
  <bpmn:process id="Process_Vendor" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Vendor">
      <bpmn:lane id="Lane_Clerk" name="clerk">
        <bpmn:flowNodeRef>StartEvent_Vendor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEvent_WhereIsMyPizza</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CalmCustomer</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Chef" name="pizza chef">
        <bpmn:flowNodeRef>Task_BakePizza</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Delivery" name="delivery boy">
        <bpmn:flowNodeRef>Task_DeliverPizza</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReceivePayment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Vendor</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Vendor" name="Order received">
      <bpmn:outgoing>Flow_V1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="ME_2" />
    </bpmn:startEvent>
    <bpmn:parallelGateway id="Gateway_Split">
      <bpmn:incoming>Flow_V1</bpmn:incoming>
      <bpmn:outgoing>Flow_V2</bpmn:outgoing>
      <bpmn:outgoing>Flow_V3</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:intermediateCatchEvent id="CatchEvent_WhereIsMyPizza" name="&#34;where is my pizza?&#34;">
      <bpmn:incoming>Flow_V2</bpmn:incoming>
      <bpmn:incoming>Flow_V_Loop</bpmn:incoming>
      <bpmn:outgoing>Flow_V4</bpmn:outgoing>
      <bpmn:messageEventDefinition id="ME_3" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_CalmCustomer" name="Calm customer">
      <bpmn:incoming>Flow_V4</bpmn:incoming>
      <bpmn:outgoing>Flow_V_Loop</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_BakePizza" name="Bake the pizza">
      <bpmn:incoming>Flow_V3</bpmn:incoming>
      <bpmn:outgoing>Flow_V5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_DeliverPizza" name="Deliver the pizza">
      <bpmn:incoming>Flow_V5</bpmn:incoming>
      <bpmn:outgoing>Flow_V6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ReceivePayment" name="Receive payment">
      <bpmn:incoming>Flow_V6</bpmn:incoming>
      <bpmn:outgoing>Flow_V7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_Vendor">
      <bpmn:incoming>Flow_V7</bpmn:incoming>
      <bpmn:terminateEventDefinition id="T_1" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_V1" sourceRef="StartEvent_Vendor" targetRef="Gateway_Split" />
    <bpmn:sequenceFlow id="Flow_V2" sourceRef="Gateway_Split" targetRef="CatchEvent_WhereIsMyPizza" />
    <bpmn:sequenceFlow id="Flow_V3" sourceRef="Gateway_Split" targetRef="Task_BakePizza" />
    <bpmn:sequenceFlow id="Flow_V4" sourceRef="CatchEvent_WhereIsMyPizza" targetRef="Task_CalmCustomer" />
    <bpmn:sequenceFlow id="Flow_V_Loop" sourceRef="Task_CalmCustomer" targetRef="CatchEvent_WhereIsMyPizza" />
    <bpmn:sequenceFlow id="Flow_V5" sourceRef="Task_BakePizza" targetRef="Task_DeliverPizza" />
    <bpmn:sequenceFlow id="Flow_V6" sourceRef="Task_DeliverPizza" targetRef="Task_ReceivePayment" />
    <bpmn:sequenceFlow id="Flow_V7" sourceRef="Task_ReceivePayment" targetRef="EndEvent_Vendor" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_Pizza">
      <bpmndi:BPMNShape id="Participant_Vendor_di" bpmnElement="Participant_Vendor" isHorizontal="true">
